{
  "$schema": "https://schemas.admara.studio/design-tokens-v1.json",
  "version": "1.1.0",
  "name": "Admara Studio Design Tokens",
  "description": "Source de vérité unique pour la DA Admara — vintage warm editorial 70s, palette olive/brick",

  "colors": {
    "olive": {
      "value": "#726D2D",
      "role": "accent-primary",
      "usage": "CTAs, liens actifs, navigation, bordures, hovers, accents textuels"
    },
    "cream": {
      "value": "#F4EFE6",
      "role": "background-primary",
      "usage": "Fond dominant site, emails, supports clients, 50-55% de chaque vue"
    },
    "sand": {
      "value": "#D9CDB6",
      "role": "background-secondary",
      "usage": "Sections, dividers, cards, hover doux, footers, 25-30% de chaque vue"
    },
    "brick": {
      "value": "#8E3A19",
      "role": "accent-deep",
      "usage": "Micro-accents, badges premium, hover deep states, sections cas portrait moody. JAMAIS en background plein. Max 5% d'une vue."
    },
    "ink": {
      "value": "#0A0A0A",
      "role": "text-primary",
      "usage": "Texte body, fond profond mode sombre, signatures, contrastes"
    }
  },

  "typography": {
    "fontFamilies": {
      "sans": {
        "value": "'Tenor Sans', system-ui, sans-serif",
        "role": "primary",
        "usage": "Body, navigation, CTAs, prix, captions, labels"
      },
      "serif": {
        "value": "'Cormorant Garamond', 'Times New Roman', serif",
        "role": "editorial",
        "usage": "Hero taglines, titres de page, citations, signature"
      }
    },
    "fontSizes": {
      "h1": { "value": "clamp(40px, 5vw, 72px)", "lineHeight": "1.1", "family": "serif", "weight": "400" },
      "h2": { "value": "clamp(32px, 4vw, 44px)", "lineHeight": "1.2", "family": "serif", "weight": "400" },
      "h3": { "value": "clamp(20px, 2.5vw, 26px)", "lineHeight": "1.3", "family": "sans", "weight": "400", "letterSpacing": "0.02em" },
      "body": { "value": "16px", "lineHeight": "1.6", "family": "sans", "weight": "400" },
      "bodyLarge": { "value": "18px", "lineHeight": "1.6", "family": "sans", "weight": "400" },
      "caption": { "value": "13px", "lineHeight": "1.4", "family": "sans", "weight": "400", "letterSpacing": "0.05em" },
      "price": { "value": "20px", "lineHeight": "1.2", "family": "sans", "weight": "400" }
    }
  },

  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "40px",
    "xxl": "64px",
    "xxxl": "96px"
  },

  "borderRadius": {
    "none": "0px",
    "sm": "4px",
    "md": "8px",
    "lg": "16px",
    "full": "9999px"
  },

  "shadows": {
    "soft": "0 2px 8px rgba(10, 10, 10, 0.04)",
    "medium": "0 8px 24px rgba(10, 10, 10, 0.08)",
    "deep": "0 16px 48px rgba(10, 10, 10, 0.12)"
  },

  "breakpoints": {
    "mobile": "640px",
    "tablet": "768px",
    "desktop": "1024px",
    "wide": "1280px"
  },

  "proportions": {
    "perViewMaxUsage": {
      "cream": "55%",
      "sand": "30%",
      "ink": "12%",
      "olive": "15%",
      "brick": "5%"
    },
    "minNeutralOnMixedBlocks": "1 neutre obligatoire si olive + brick présents"
  },

  "antiPatterns": {
    "bannedColors": [
      "#8B0000 (bordeaux)",
      "#5C0F0F (deep red)",
      "#320C4C (purple)",
      "#FFD700 (gold)",
      "#C0C0C0 (silver)",
      "Tout magenta, lilas, néon"
    ],
    "bannedFonts": [
      "Inter (use Tenor Sans instead)",
      "Helvetica",
      "Arial",
      "Times (use Cormorant Garamond instead)",
      "Toute font hors Tenor Sans + Cormorant Garamond"
    ],
    "bannedEffects": [
      "drop-shadow saturated",
      "neon glow",
      "glitter / sparkle",
      "drama lighting",
      "gradient saturé multi-stops",
      "Brick en background plein écran",
      "Olive + Brick sans neutre intermédiaire"
    ]
  }
}
